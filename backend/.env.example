# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Public URL of THIS backend (no trailing slash).
# Used to build the OAuth redirect URIs when they aren't set explicitly.
# In production set this to https://yourdomain.com
BACKEND_URL=http://localhost:4000

# Public URL of the React frontend (no trailing slash).
# The OAuth callback redirects the browser here after sign-in.
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────
# Microsoft OAuth (Azure app registration) — login + email sending
# See docs/05-microsoft-setup.md
# ─────────────────────────────────────────────────────────────
MS_CLIENT_ID=your-azure-app-application-client-id
MS_CLIENT_SECRET=your-azure-app-client-secret-VALUE

# Authority tenant segment:
#   common    -> personal Microsoft + work/school accounts
#   consumers -> personal Microsoft accounts only (outlook.com/hotmail/live)
#   <tenant-id> -> a single Microsoft 365 tenant
MS_TENANT=common

# Must EXACTLY match "Redirect URIs" registered on the Azure app (Web platform):
#   End-user login callback:
MS_LOGIN_REDIRECT_URI=http://localhost:4000/auth/microsoft/callback
#   One-time sender-mailbox authorization callback:
MS_MAIL_REDIRECT_URI=http://localhost:4000/auth/microsoft/mail-callback

# The outlook.com address that will SEND the emails (for display + login hint).
MAIL_SENDER=youraddress@outlook.com

# Where MSAL persists the sender's token cache + account id (keep OUT of git).
MS_TOKEN_CACHE_PATH=./.mail-token-cache.json
MS_MAIL_ACCOUNT_PATH=./.mail-account.json

# ─────────────────────────────────────────────────────────────
# Google Sheets  (Step 2 + Step 3) — service account only
# ─────────────────────────────────────────────────────────────
# The long ID in the sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=1nIBioJRkuDLBAuFRiXnbj0Ngv7UZw2nT7WivYo7XXj4

# The TAB name (bottom of the sheet), NOT the file name. Default in a new sheet is "Sheet1".
GOOGLE_SHEET_NAME=Sheet1

# Path to the downloaded service account JSON key (Step 2).
SERVICE_ACCOUNT_KEY_PATH=./service-account.json

# OPTIONAL alternative for hosts that don't allow committing files
# (Railway/Render/etc). Paste the WHOLE service-account.json, base64-encoded.
# If set, this takes precedence over SERVICE_ACCOUNT_KEY_PATH.
# SERVICE_ACCOUNT_KEY_BASE64=

# ─────────────────────────────────────────────────────────────
# API security  (Step 7) - shared secret with Apps Script
# ─────────────────────────────────────────────────────────────
API_KEY=generate-a-long-random-string
